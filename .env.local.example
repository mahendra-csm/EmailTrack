# Copy this file to .env.local and fill in your real SMTP credentials.
# These two accounts are seeded into the smtp_accounts table on first run
# (only if the table is empty). Treat them as a rotating pool.
#
# Hostinger example: host=smtp.hostinger.com, port=465 (SSL) or 587 (TLS).

# Per-mailbox HOURLY send cap — keeps Hostinger from auto-disabling a box that
# bursts. Applies to all accounts unless overridden per-account (SMTP1_HOURLY_LIMIT).
# Start conservative (~80-100/hour) and tune on the Senders page.
SMTP_HOURLY_LIMIT=100

SMTP1_HOST=smtp.hostinger.com
SMTP1_PORT=465
SMTP1_EMAIL=you@yourdomain.com
SMTP1_PASSWORD=your-mailbox-password
SMTP1_LIMIT=3000
# SMTP1_HOURLY_LIMIT=100

SMTP2_HOST=smtp.hostinger.com
SMTP2_PORT=465
SMTP2_EMAIL=you2@yourdomain.com
SMTP2_PASSWORD=your-second-mailbox-password
SMTP2_LIMIT=3000

# Display name used in the "From" header (optional)
MAIL_FROM_NAME=Your Company

# Milliseconds to wait between individual sends (throttle to stay SMTP-safe)
SEND_DELAY_MS=400

# Auto-send: an external scheduler (cron-job.org) pings
#   https://<your-app>/api/cron/tick?key=CRON_SECRET   every 2-5 minutes.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=replace-with-a-long-random-secret
# How many emails each ping sends (1-200). Keep modest to finish within 60s.
CRON_BATCH_SIZE=50
# Retry policy: max attempts per email, and backoff minutes between attempts.
MAX_SEND_ATTEMPTS=3
RETRY_BACKOFF_MIN=30

# Daily send window in UTC (optional). If set, the scheduler only sends between
# START and END, so every batch (incl. follow-ups) goes out at the same local
# hours. Times are UTC; IST = UTC+5:30.
#   9:30 AM IST = 04:00 UTC ; 5:00 AM IST (next day) = 23:30 UTC
# -> sends 9:30 AM to 5:00 AM IST, pauses 5:00-9:30 AM.
SEND_WINDOW_START=04:00
SEND_WINDOW_END=23:30

# Public base URL — REQUIRED for open/click tracking + one-click unsubscribe.
APP_URL=https://your-app.vercel.app
# Optional: separate secret for tracking/unsubscribe link signing (defaults to CRON_SECRET).
# TRACK_SECRET=another-long-random-secret
# Reply detection IMAP host (defaults to the SMTP host with smtp.->imap.).
IMAP_HOST=imap.hostinger.com
