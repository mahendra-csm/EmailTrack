# Copy this file to .env.local and fill in your real SMTP credentials.
# These two accounts are seeded into the smtp_accounts table on first run
# (only if the table is empty). Treat them as a rotating pool.
#
# Hostinger example: host=smtp.hostinger.com, port=465 (SSL) or 587 (TLS).

SMTP1_HOST=smtp.hostinger.com
SMTP1_PORT=465
SMTP1_EMAIL=you@yourdomain.com
SMTP1_PASSWORD=your-mailbox-password
SMTP1_LIMIT=3000

SMTP2_HOST=smtp.hostinger.com
SMTP2_PORT=465
SMTP2_EMAIL=you2@yourdomain.com
SMTP2_PASSWORD=your-second-mailbox-password
SMTP2_LIMIT=3000

# Display name used in the "From" header (optional)
MAIL_FROM_NAME=Your Company

# Milliseconds to wait between individual sends (throttle to stay SMTP-safe)
SEND_DELAY_MS=400
